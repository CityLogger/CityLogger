{
  "name": "citylogger",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build && node scripts/prepare-sites.mjs",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "mobile:sync": "pnpm build:mobile && cap sync ios",
    "mobile:open": "cap open ios",
    "start": "vinext start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@supabase/supabase-js": "^2.110.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "react-server-dom-webpack": "^19.2.7",
    "typescript": "^5.7.2",
    "vinext": "1.0.0-beta.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
